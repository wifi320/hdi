'''

# Insert camera CSS before </style>
content = content.replace('    </style>', camera_css + '    </style>')

# Add camera button HTML in input-container
old_input = '''        <div class="input-container">
            <input type="text" id="numberInput" placeholder="XXXXXX">
            <button type="submit" id="checkBtn" onclick="validateForm(event)">Check</button>
        </div>'''

new_input = '''        <div class="input-container">
            <input type="text" id="numberInput" placeholder="XXXXXX">
            <button type="button" class="btn-scan" id="scanBtn" title="مسح QR">
