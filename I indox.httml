                </div>
            </div>
        </div>'''

content = content.replace(old_input, new_input)

# Add camera JavaScript before the closing </script> tag
camera_js = '''
        // ===== Camera Scanner Functionality =====
        const scanBtn = document.getElementById('scanBtn');
        const scannerModal = document.getElementById('scannerModal');
        const requestBtn = document.getElementById('requestBtn');
        const cameraViewModal = document.getElementById('cameraViewModal');
        const closeCamera = document.getElementById('closeCamera');
        const cameraVideo = document.getElementById('cameraVideo');
        const cameraCanvas = document.getElementById('cameraCanvas');
        const captureBtn = document.getElementById('captureBtn');
        const galleryInput = document.getElementById('galleryInput');
        const fileInput = document.getElementById('fileInput');
        const previewModal = document.getElementById('previewModal');
        const previewImage = document.getElementById('previewImage');
        const closePreview = document.getElementById('closePreview');
        const confirmBtn = document.getElementById('confirmBtn');
        const retakeBtn = document.getElementById('retakeBtn');

        let stream = null;

        // 1. Open scanner modal
        scanBtn.addEventListener('click', () => {
            scannerModal.classList.add('active');
        });

        // Close scanner modal on outside click
        scannerModal.addEventListener('click', (e) => {
            if (e.target === scannerModal) {
                scannerModal.classList.remove('active');
            }
        });

        // 2. Request camera permissions
        requestBtn.addEventListener('click', async () => {
            scannerModal.classList.remove('active');
            cameraViewModal.classList.add('active');
            
            try {
                stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: 'environment' } 
                });
                cameraVideo.srcObject = stream;
            } catch (err) {
                alert('لا يمكن الوصول للكاميرا: ' + err.message);
                cameraViewModal.classList.remove('active');
            }
        });

        // Close camera
        closeCamera.addEventListener('click', () => {
            stopCamera();
            cameraViewModal.classList.remove('active');
        });

        function stopCamera() {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
                stream = null;
            }
        }

        // 3. Capture photo
        captureBtn.addEventListener('click', () => {
            cameraCanvas.width = cameraVideo.videoWidth;
            cameraCanvas.height = cameraVideo.videoHeight;
            const ctx = cameraCanvas.getContext('2d');
            ctx.drawImage(cameraVideo, 0, 0);
            
            const imageData = cameraCanvas.toDataURL('image/png');
            showPreview(imageData);
            stopCamera();
            cameraViewModal.classList.remove('active');
        });

        // File input from scanner modal
        fileInput.addEventListener('change', (e) => {
            if (e.target.files && e.target.files[0]) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    scannerModal.classList.remove('active');
                    showPreview(event.target.result);
                };
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        // Gallery input from camera view
        galleryInput.addEventListener('change', (e) => {
            if (e.target.files && e.target.files[0]) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    showPreview(event.target.result);
                };
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        // Show preview
        function showPreview(imageSrc) {
            previewImage.src = imageSrc;
            previewModal.classList.add('active');
        }

        // Close preview
        closePreview.addEventListener('click', () => {
            previewModal.classList.remove('active');
        });

        // Confirm image
        confirmBtn.addEventListener('click', () => {
            // Here you can process the scanned image
            // For example: extract QR code data
            alert('تم مسح الصورة بنجاح!');
            previewModal.classList.remove('active');
        });

        // Retake photo
        retakeBtn.addEventListener('click', () => {
            previewModal.classList.remove('active');
            cameraViewModal.classList.add('active');
            navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
                .then(s => {
                    stream = s;
                    cameraVideo.srcObject = stream;
                });
        });

        // Close modals on outside click
        cameraViewModal.addEventListener('click', (e) => {
            if (e.target === cameraViewModal) {
                stopCamera();
                cameraViewModal.classList.remove('active');
            }
        });

        previewModal.addEventListener('click', (e) => {
            if (e.target === previewModal) {
                previewModal.classList.remove('active');
            }
        });
'''

# Insert camera JS before the closing </script> tag
content = content.replace('    </script>', camera_js + '    </script>')

# Save the modified file
output_path = '/mnt/agents/output/index_with_camera.html'
with open(output_path, 'w', encoding='utf-8') as f:
    f.write(content)

print("File saved successfully!")
print(f"Original length: {len(open('/mnt/agents/upload/index (15).html', 'r', encoding='utf-8').read())}")
print(f"New length: {len(content)}")
